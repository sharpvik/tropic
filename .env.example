# --- HTTP ---
PORT=8080

# --- GitLab ---
GITLAB_BASE_URL=https://gitlab.example.com
# Must match the "Secret token" configured on the GitLab webhook.
GITLAB_WEBHOOK_SECRET=change-me-openssl-rand-hex-32
# Project or group access token, scope: api
GITLAB_BOT_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx
# The GitLab username the bot logs in as; assignment to this user triggers a run.
CLAUDE_BOT_USERNAME=claude-bot

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# Optional: pin a model; defaults to the SDK's latest.
# ANTHROPIC_MODEL=claude-opus-4-8

# --- Behaviour / guard rails ---
MAX_CONCURRENCY=2
JOB_TIMEOUT_MS=1800000
MAX_TURNS=40

# --- Storage ---
WORKSPACES_DIR=./workspaces
DATA_DIR=./data

# --- Git identity for commits pushed by the bot ---
BOT_GIT_USERNAME=claude-bot
BOT_GIT_EMAIL=claude-bot@example.com

# --- Optional allowlist: comma-separated GitLab project IDs the service will act on.
# Leave empty to allow all projects whose webhooks reach this service.
# ALLOWED_PROJECTS=42,101
